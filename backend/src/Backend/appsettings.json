{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "AntennaMonitoring": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=antenna_monitoring;Username=postgres;Password=postgres;Pooling=true;",
    "InfluxDB": "http://localhost:8086"
  },
  "InfluxDB": {
    "Url": "http://localhost:8086",
    "Token": "5g-antenna-monitoring-token-2024",
    "Org": "5g-operator",
    "Buckets": {
      "Metrics": "antenna_metrics",
      "Calibration": "antenna_calibration",
      "Diagnosis": "antenna_diagnosis"
    }
  },
  "MQTT": {
    "Broker": "localhost",
    "Port": 1883,
    "ClientId": "antenna-monitoring-service",
    "Topics": {
      "Alarm": "5g/antenna/alarm",
      "Calibration": "5g/antenna/calibration",
      "ECPRI": "5g/antenna/ecpri/+"
    },
    "UserName": "antenna_admin",
    "Password": "mqtt_password_2024"
  },
  "ECPRI": {
    "ListenPort": 50000,
    "BufferSize": 65536,
    "MaxConnections": 200
  },
  "Calibration": {
    "Algorithm": "Kalman",
    "RequiredSLL": -20.0,
    "MaxIterations": 100,
    "ConvergenceThreshold": 1e-6,
    "IntervalMinutes": 5
  },
  "Diagnosis": {
    "ModelType": "RandomForest",
    "FailureProbabilityThreshold": 0.7,
    "SWRAlarmThreshold": 2.0,
    "SectorFailureChannelRatio": 0.1,
    "IntervalMinutes": 5,
    "PredictionHorizonHours": 24
  }
}
